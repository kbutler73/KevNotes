<UserControl x:Class="KevNotes.KevNotesToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
             Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="MyToolWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="0">
            <ComboBox x:Name="cboFontFamily" SelectionChanged="cboFontFamily_SelectionChanged"></ComboBox>
            <Button x:Name="btnFontDown" Width="24" Height="24" MinWidth="24" MinHeight="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Click="Button_Click">-</Button>
            <Button x:Name="btnFontUp" Width="24" Height="24" MinWidth="24" MinHeight="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Click="Button_Click_1">+</Button>
        </StackPanel>
        <Border x:Name="FindBar" Grid.Row="1"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center" Text="Find"></TextBlock>
                <TextBox x:Name="tbFind" Grid.Row="0" Grid.Column="1" MinWidth="160" Margin="0,0,6,0"
                         KeyDown="tbFind_KeyDown" TextChanged="tbFind_TextChanged"></TextBox>
                <Button x:Name="btnFindNext" Grid.Row="0" Grid.Column="2" Margin="0,0,6,0" Click="FindNext_Click">Next</Button>
                <CheckBox x:Name="cbMatchCase" Grid.Row="0" Grid.Column="4" Margin="0,0,6,0" VerticalAlignment="Center"
                          Content="Match case"></CheckBox>

                <Grid x:Name="ReplaceRow" Grid.Row="1" Grid.ColumnSpan="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,6,6,0" VerticalAlignment="Center" Text="Replace"></TextBlock>
                    <TextBox x:Name="tbReplace" Grid.Column="1" Margin="0,6,6,0"
                             KeyDown="tbReplace_KeyDown"></TextBox>
                    <Button x:Name="btnReplace" Grid.Column="2" Margin="0,6,6,0" Click="Replace_Click">Replace</Button>
                    <Button x:Name="btnReplaceAll" Grid.Column="3" Margin="0,6,6,0" Click="ReplaceAll_Click">Replace All</Button>
                </Grid>
            </Grid>
        </Border>
        <RichTextBox x:Name="rtbNotes" Grid.Row="2"
                 Background="Transparent"
                 Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                 CaretBrush="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 IsDocumentEnabled="True"
                 TextChanged="rtbNotes_TextChanged"
                 PreviewKeyDown="rtbNotes_PreviewKeyDown"
                 LostFocus="rtbNotes_LostFocus">
            <RichTextBox.Resources>
                <Style TargetType="{x:Type Paragraph}">
                    <Setter Property="Margin" Value="0" />
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>
    </Grid>
</UserControl>
